<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Pagamento de Reenvio - <%= order.code %></title>
  <link rel="stylesheet" href="/css/style.css">
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
  <link rel="stylesheet" href="https://npmcdn.com/flatpickr/dist/themes/material_blue.css">
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
  <script src="https://npmcdn.com/flatpickr/dist/l10n/pt.js"></script>
</head>
<body>
  <div class="page-wrap">
    <%- include('partials/header') %>

    <main class="main-container">

      <!-- Breadcrumb -->
      <div class="breadcrumb">
        <a href="/">Inicio</a>
        <span class="separator"><i class="fas fa-chevron-right"></i></span>
        <a href="/rastreio/<%= order.code %>">Rastreio</a>
        <span class="separator"><i class="fas fa-chevron-right"></i></span>
        <span class="current">Pagamento de Reenvio</span>
      </div>

      <div class="card">
        <div class="card-header">
          <div class="header-title">
            <div class="icon-box icon-box--payment">
              <i class="fas fa-wallet"></i>
            </div>
            <h2>Pagamento de Reenvio</h2>
          </div>
        </div>

        <div class="card-body">

          <!-- Payment Alert -->
          <div class="payment-alert">
            <div class="payment-alert-body">
              <div class="payment-alert-icon">
                <i class="fas fa-exclamation-circle"></i>
              </div>
              <div class="payment-alert-text">
                <strong>Taxa de Reenvio</strong>
                <p>
                  Devido a tentativa de entrega falhada, e necessario pagar uma taxa de <strong>&euro; 5,00</strong>.
                </p>
              </div>
            </div>
            <div class="payment-order-badge">
              <span class="badge-label">Pedido:</span>
              <span class="badge-code"><%= order.code %></span>
            </div>
          </div>

          <form id="paymentForm">

            <!-- Step 1: Date -->
            <div class="form-section">
              <h3 class="form-section-title">
                <i class="fas fa-calendar-alt"></i>
                1. Escolha a nova data
              </h3>
              <p class="form-hint">Datas disponiveis abaixo.</p>

              <div class="date-input-wrapper">
                <i class="fas fa-calendar-check date-icon"></i>
                <input type="text" id="redeliveryDate" name="redeliveryDate" required
                       class="date-input"
                       placeholder="Selecione uma data disponivel...">
              </div>
            </div>

            <!-- Step 2: Payment Method -->
            <div class="form-section">
              <h3 class="form-section-title">
                <i class="fas fa-credit-card"></i>
                2. Metodo de Pagamento
              </h3>

              <div class="payment-methods">
                <label class="payment-option" onclick="togglePhoneInput(true)">
                  <input type="radio" name="paymentMethod" value="mbway" checked>
                  <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/e/e3/Logo_MBWay.svg/1280px-Logo_MBWay.svg.png" alt="MB WAY">
                </label>

                <label class="payment-option" onclick="togglePhoneInput(false)">
                  <input type="radio" name="paymentMethod" value="multibanco">
                  <img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcRztdexX5nIB1qqQKdKFlXSTDWDDWbRkBFggA&s" alt="Multibanco">
                </label>
              </div>

              <!-- MB WAY Phone Input -->
              <div id="mbwayPhoneGroup" class="phone-input-group" style="display: block;">
                <label class="phone-label">Numero de Telemovel MB WAY:</label>
                <div class="phone-input-wrapper">
                  <div class="phone-prefix">
                    <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/5/5c/Flag_of_Portugal.svg/2560px-Flag_of_Portugal.svg.png" class="phone-flag" alt="PT">
                    +351
                  </div>
                  <input type="tel" id="phoneNumber" name="phoneNumber" placeholder="912 345 678" maxlength="9"
                         class="phone-input">
                </div>
                <small class="form-help">Insira o numero associado a sua conta MB WAY.</small>
              </div>
            </div>

            <button type="submit" id="submitBtn" class="btn-submit">
              Pagar &euro; 5,00 e Reagendar <i class="fas fa-check-circle"></i>
            </button>
          </form>

          <div class="footer-actions">
            <a href="/rastreio/<%= order.code %>" class="btn-link">
              <i class="fas fa-times"></i> Cancelar e Voltar
            </a>
          </div>
        </div>
      </div>

    </main>

    <%- include('partials/footer') %>
  </div>

  <script>
    // Show/Hide phone input based on payment method
    function togglePhoneInput(show) {
      var phoneGroup = document.getElementById('mbwayPhoneGroup');
      var phoneInput = document.getElementById('phoneNumber');

      if (show) {
        phoneGroup.style.display = 'block';
        phoneInput.required = true;
      } else {
        phoneGroup.style.display = 'none';
        phoneInput.required = false;
        phoneInput.value = '';
      }
    }

    // Initialize toggle state
    document.addEventListener('DOMContentLoaded', function() {
      var mbwayRadio = document.querySelector('input[name="paymentMethod"][value="mbway"]');
      if (mbwayRadio && mbwayRadio.checked) {
        togglePhoneInput(true);
      } else {
        togglePhoneInput(false);
      }
    });

    // Form submission handler
    var form = document.getElementById('paymentForm');
    form.addEventListener('submit', async function(e) {
      e.preventDefault();

      var submitBtn = form.querySelector('button[type="submit"]');
      var originalBtnText = submitBtn.innerHTML;
      submitBtn.disabled = true;
      submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Processando...';

      var formData = new FormData(form);
      var data = Object.fromEntries(formData.entries());

      // Validate MB WAY phone
      if (data.paymentMethod === 'mbway') {
        var phone = document.getElementById('phoneNumber').value;
        if (!phone || phone.length < 9) {
          Swal.fire({
            icon: 'warning',
            title: 'Numero Invalido',
            text: 'Por favor, insira um numero de telemovel valido para o pagamento MB WAY.',
            confirmButtonColor: '#4834D4'
          });
          submitBtn.disabled = false;
          submitBtn.innerHTML = originalBtnText;
          return;
        }
        data.phoneNumber = phone;
      }

      try {
        var response = await fetch('/api/reenvio/<%= order.code %>/create-payment', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        });

        var result = await response.json();

        if (result.success) {
          if (data.paymentMethod === 'mbway') {
            Swal.fire({
              title: 'Pagamento Iniciado!',
              html:
                '<div style="text-align: center;">' +
                  '<img src="https://upload.wikimedia.org/wikipedia/commons/thumb/e/e3/Logo_MBWay.svg/1280px-Logo_MBWay.svg.png" style="height: 50px; margin-bottom: 20px;">' +
                  '<p>Enviamos um pedido de pagamento para o numero:</p>' +
                  '<p style="font-size: 1.2rem; font-weight: bold; margin: 10px 0;">' + data.phoneNumber + '</p>' +
                  '<p>Por favor, aceite a transacao na app MB WAY.</p>' +
                  '<div style="margin: 20px 0; font-size: 1.2rem; font-weight: bold;">&euro; 5,00</div>' +
                  '<div class="timer" style="color: #666; font-size: 0.9rem;">Aguardando confirmacao... <span id="countdown">90</span>s</div>' +
                '</div>',
              showConfirmButton: false,
              allowOutsideClick: false,
              didOpen: function() {
                var timeLeft = 90;
                var timer = setInterval(function() {
                  var el = document.getElementById('countdown');
                  if (el) el.innerText = --timeLeft;
                  if (timeLeft <= 0) {
                    clearInterval(timer);
                    Swal.fire({
                      title: 'Tempo Esgotado',
                      text: 'O tempo para aceitar o pagamento expirou.',
                      icon: 'warning'
                    });
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = originalBtnText;
                  }
                }, 1000);

                // Poll for payment status
                var checkStatus = setInterval(async function() {
                  try {
                    var statusResponse = await fetch('/api/reenvio/' + (data.paymentId || result.paymentId) + '/check-status');
                    var statusResult = await statusResponse.json();

                    if (statusResult.paid) {
                      clearInterval(checkStatus);
                      clearInterval(timer);
                      Swal.fire({
                        icon: 'success',
                        title: 'Pagamento Confirmado!',
                        text: 'Seu reenvio foi agendado com sucesso.',
                        confirmButtonText: 'Ver Rastreio',
                        confirmButtonColor: '#4834D4'
                      }).then(function() {
                        window.location.href = '/rastreio/<%= order.code %>';
                      });
                    }
                  } catch(e) { console.error(e); }
                }, 3000);
              }
            }).then(function() {
              window.location.reload();
            });

          } else {
            // Multibanco Flow
            Swal.fire({
              title: 'Dados para Pagamento',
              html:
                '<div style="text-align: center;">' +
                  '<img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcRztdexX5nIB1qqQKdKFlXSTDWDDWbRkBFggA&s" style="height: 50px; margin-bottom: 20px;">' +
                  '<div style="background: #f8f9fa; padding: 15px; border-radius: 8px; text-align: left; margin-bottom: 15px;">' +
                    '<p style="margin: 5px 0; display: flex; justify-content: space-between;"><span>Entidade:</span> <strong>' + (result.entity || '12345') + '</strong></p>' +
                    '<p style="margin: 5px 0; display: flex; justify-content: space-between;"><span>Referencia:</span> <strong>' + (result.reference || '123 456 789') + '</strong></p>' +
                    '<p style="margin: 5px 0; display: flex; justify-content: space-between;"><span>Valor:</span> <strong>&euro; 5,00</strong></p>' +
                  '</div>' +
                  '<p style="font-size: 0.9rem; color: #666;">Realize o pagamento em qualquer caixa Multibanco ou Homebanking.</p>' +
                '</div>',
              showConfirmButton: false,
              didOpen: function() {
                var checkStatus = setInterval(async function() {
                  try {
                    var statusResponse = await fetch('/api/reenvio/' + (data.paymentId || result.paymentId) + '/check-status');
                    var statusResult = await statusResponse.json();

                    if (statusResult.paid) {
                      clearInterval(checkStatus);
                      Swal.fire({
                        icon: 'success',
                        title: 'Pagamento Confirmado!',
                        text: 'Seu reenvio foi agendado com sucesso.',
                        confirmButtonText: 'Ver Rastreio',
                        confirmButtonColor: '#4834D4'
                      }).then(function() {
                        window.location.href = '/rastreio/<%= order.code %>';
                      });
                    }
                  } catch(e) { console.error(e); }
                }, 5000);
              }
            });
          }

        } else {
          throw new Error(result.error || 'Erro desconhecido');
        }

      } catch (error) {
        Swal.fire('Erro!', error.message, 'error');
        submitBtn.disabled = false;
        submitBtn.innerHTML = originalBtnText;
      }
    });

    async function confirmPayment(paymentId, date) {
      try {
        var response = await fetch('/api/reenvio/<%= order.code %>/confirm', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ paymentId: paymentId, redeliveryDate: date })
        });

        var result = await response.json();

        if (result.success) {
          Swal.fire({
            icon: 'success',
            title: 'Pagamento Confirmado!',
            text: 'Seu reenvio foi agendado com sucesso.',
            confirmButtonText: 'Ver Rastreio',
            confirmButtonColor: '#4834D4'
          }).then(function() {
            window.location.href = '/rastreio/<%= order.code %>';
          });
        } else {
          throw new Error(result.error);
        }
      } catch (e) {
        Swal.fire('Erro', 'Falha ao confirmar pagamento.', 'error');
      }
    }

    // Init Flatpickr
    flatpickr("#redeliveryDate", {
      dateFormat: "Y-m-d",
      altInput: true,
      altFormat: "d/m/Y",
      minDate: "<%= minDate %>",
      maxDate: "<%= maxDate %>",
      locale: "pt",
      disableMobile: "true",
      theme: "material_blue",
      onOpen: function(selectedDates, dateStr, instance) {
        instance.calendarContainer.classList.add('custom-calendar');
      }
    });

    // Date validation backup
    var dateInput = document.getElementById('redeliveryDate');
    dateInput.addEventListener('change', function() {
      var selected = new Date(this.value);
      var min = new Date('<%= minDate %>');
      var max = new Date('<%= maxDate %>');

      if (selected < min) {
        alert('A data deve ser a partir de ' + min.toLocaleDateString('pt-BR'));
        this.value = '<%= minDate %>';
      } else if (selected > max) {
        alert('A data nao pode exceder 30 dias.');
        this.value = '<%= maxDate %>';
      }
    });
  </script>
</body>
</html>
